# dnsmasq configuration for Split DNS usage (Tailscale)
# Generated by Ansible - do not edit manually
#
# Intended to run as the DNS server referenced by Tailscale Split DNS (single place of truth for zones).
# This config deliberately does NOT mention specific domains; it answers every query it receives with target_ip.

interface=tailscale0
bind-dynamic

{# When used as a Split DNS nameserver, dnsmasq should listen on 53. #}
port={{ dnsmasq_port | default(53) }}

# Enable logging
log-queries
log-dhcp
log-facility=/var/log/dnsmasq.log

# Answer EVERYTHING with the same IP.
# Safe only when dnsmasq is reached via domain-scoped routing (e.g. Tailscale Split DNS).
address=/#/{{ target_ip }}

# Optional forwarding (should not be used for split-zones, but helps if anything else reaches this server)
no-resolv
server=1.1.1.1
server=9.9.9.9

# Cache settings
cache-size=1000
neg-ttl=3600

# Don't read /etc/hosts
no-hosts
