# Main dnsmasq configuration
# Generated by Ansible - do not edit manually

interface=lo
interface=tailscale0
bind-dynamic



# Enable logging
log-queries
log-dhcp
log-facility=/var/log/dnsmasq.log

{% set domains = base_domains | default([base_domain]) %}

# Only handle configured environment domains and subdomains.
# This will resolve ANY subdomain under each suffix to the specified IP.
{% for domain in domains %}
address=/{{ target_env }}.{{ domain }}/{{ target_ip }}
address=/*.{{ target_env }}.{{ domain }}/{{ target_ip }}
{% endfor %}

# Forward other queries to upstream DNS
no-resolv
server=1.1.1.1
server=9.9.9.9

# Cache settings
cache-size=1000
neg-ttl=3600

# Don't read /etc/hosts
no-hosts
